<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laboratorio Suono</title>
    <style>
        @font-face {
        font-family: 'EasyReading';
        /* Assicurati che il percorso (src) punti correttamente ai tuoi file */
        src: url('Fonts/EasyReadingPRO.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        }

        :root {
            --primary: #3498db;
            --bg: #f8f9fa;
            --card-bg: #ffffff;
        }

        body {
            /* 2. MODIFICA IL FONT-FAMILY QUI */
            font-family: 'EasyReading', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            max-width: 800px;
            width: 100%;
        }

        h1 { 
            color: #2c3e50; 
            text-align: center; 
        }

        .question-card {
            background: var(--card-bg);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }

        .question-text {
            font-size: 1.3em;
            font-weight: bold;
            margin-bottom: 25px;
            color: #34495e;
        }

        .option-row {
            display: flex;
            align-items: stretch;
            margin-bottom: 15px;
            border: 2px solid #ecf0f1;
            border-radius: 10px;
            overflow: hidden;
            background: white;
        }

        .visible-option {
            flex: 1;
            padding: 15px;
            display: flex;
            align-items: center;
            font-size: 1.1em;
            font-weight: bold;
            color: #2c3e50;
            border-right: 2px solid #ecf0f1;
        }

        .scratch-wrapper {
            flex: 1.5; 
            position: relative;
            min-height: 80px;
            background: #fff;
        }

        .feedback-content {
            padding: 15px;
            display: flex;
            align-items: center;
            height: 100%;
            box-sizing: border-box;
            font-weight: 500;
            line-height: 1.4;
            opacity: 0;
        }

        .correct { background-color: #d4edda; color: #155724; }
        .wrong { background-color: #f8d7da; color: #721c24; }

        .scratch-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            cursor: crosshair;
            touch-action: none;
        }

        .nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            background: white;
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1em;
        }

        button:hover { background: #2980b9; }
        button:disabled { background: #bdc3c7; cursor: not-allowed; }
        
        #pageInfo { font-weight: bold; font-size: 1.1em; color: #7f8c8d; }

        @media (max-width: 600px) {
            .option-row { flex-direction: column; }
            .visible-option { border-right: none; border-bottom: 2px solid #ecf0f1; }
            .scratch-wrapper { min-height: 100px; }
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🎯 Fisica: Onde Meccaniche</h1>
    <div id="quiz-container"></div>
    
    <div class="nav">
        <button id="prevBtn" onclick="changePage(-1)">⬅️ Precedente</button>
        <span id="pageInfo"></span>
        <button id="nextBtn" onclick="changePage(1)">Successiva ➡️</button>
    </div>
</div>

<script>
    // ==========================================
    // 1. DATABASE DOMANDE E RISPOSTE
    // ==========================================
    
    const DATABASE_DOMANDE = [
        {
            "domanda": "Quale delle seguenti è una condizione necessaria per la propagazione di un'onda meccanica?",
            "risposte": [
                { "visibile": "A) La presenza del vuoto", "feedback": "Errato!" },
                { "visibile": "B) La presenza di un mezzo materiale", "feedback": "Corretto!" },
                { "visibile": "C) Un campo elettromagnetico", "feedback": "Errato!" },
                { "visibile": "D) L'assenza di gravità", "feedback": "Errato!" }
            ]
        },
        {
            "domanda": "Cosa viene trasportato da un'onda durante la sua propagazione?",
            "risposte": [
                { "visibile": "A) Materia e atomi", "feedback": "Errato!" },
                { "visibile": "B) Energia ma non materia", "feedback": "Corretto!" },
                { "visibile": "C) Sia energia che materia", "feedback": "Errato!" },
                { "visibile": "D) Particelle del mezzo cariche elettricamente", "feedback": "Errato!" }
            ]
        },
        {
            domanda: "In quale di questi mezzi il suono si propaga generalmente più velocemente?",
            risposte: [
                { visibile: "A) Aria a 0°C", feedback: "Errato!" },
                { visibile: "B) Acqua", feedback: "Errato!" },
                { visibile: "C) Acciaio", feedback: "Corretto!" },
                { visibile: "D) Vuoto", feedback: "Errato!" }
            ]
        },
        {
            "domanda": "Da cosa dipende principalmente la velocità di propagazione di un'onda meccanica (come il suono) in un certo ambiente?",
            "risposte": [
                { "visibile": "A) Dalla frequenza della sorgente che l'ha generata.", "feedback": "Errato!" },
                { "visibile": "B) Dall'ampiezza dell'onda (onde più 'forti' viaggiano più veloci).", "feedback": "Errato!" },
                { "visibile": "C) Dalle proprietà fisiche del mezzo in cui si propaga (come densità ed elasticità).", "feedback": "Corretto!" },
                { "visibile": "D) Dalla distanza tra la sorgente e l'osservatore.", "feedback": "Errato!" }
            ]
        },
        {
            "domanda": "In un film di fantascienza, due astronavi si scontrano nello spazio profondo generando una fragorosa esplosione. Da un punto di vista strettamente fisico, l'audio di questa scena è accurato?",
            "risposte": [
                { "visibile": "A) Sì, se l'esplosione è abbastanza forte da generare onde d'urto nel vuoto.", "feedback": "Errato!" },
                { "visibile": "B) No, perché il suono è un'onda meccanica e necessita di un mezzo materiale per propagarsi.", "feedback": "Corretto!" },
                { "visibile": "C) Sì, perché nello spazio le onde sonore si convertono automaticamente in onde radio.", "feedback": "Errato!" },
                { "visibile": "D) No, perché le bassissime temperature dello spazio rallentano il suono fino a fermarlo.", "feedback": "Errato!" }
            ]
        },
        {
            "domanda": "Se raddoppi la frequenza di un'onda che viaggia lungo una corda mantenuta a una tensione costante, cosa succede alla sua velocità?",
            "risposte": [
                { "visibile": "A) Raddoppia.", "feedback": "Errato!" },
                { "visibile": "B) Si dimezza.", "feedback": "Errato!" },
                { "visibile": "C) Rimane invariata.", "feedback": "Corretto!" },
                { "visibile": "D) Quadruplica.", "feedback": "Errato!" }
            ]
        },
        {
            "domanda": "In un'onda trasversale che si propaga verso destra lungo una lunga corda elastica orizzontale, in quale direzione si muove un singolo punto marcato in rosso sulla corda?",
            "risposte": [
                { "visibile": "A) Verso destra, spinto dall'onda.", "feedback": "Errato!" },
                { "visibile": "B) In un percorso perfettamente circolare.", "feedback": "Errato!" },
                { "visibile": "C) Esclusivamente su e giù, perpendicolarmente alla corda.", "feedback": "Corretto!" },
                { "visibile": "D) Verso sinistra, reagendo al passaggio dell'onda.", "feedback": "Errato!" }
            ]
        },
        {
            "domanda": "Due impulsi d'onda positivi (creste) viaggiano l'uno verso l'altro lungo la stessa corda. Cosa succede esattamente nel momento in cui si sovrappongono?",
            "risposte": [
                { "visibile": "A) Rimbalzano l'uno contro l'altro, invertendo la loro direzione.", "feedback": "Errato!" },
                { "visibile": "B) Si annullano a vicenda e la corda rimane piatta in quel punto.", "feedback": "Errato!" },
                { "visibile": "C) Si sommano generando un'onda temporanea di ampiezza maggiore, poi riprendono il loro cammino originario.", "feedback": "Corretto!" },
                { "visibile": "D) Si fondono in un unico grande impulso che rimane fermo nel punto di incontro.", "feedback": "Errato!" }
            ]
        },
        {
            domanda: "Un treno in avvicinamento a una stazione fischia. Un passeggero fermo in banchina sente un suono che, rispetto a quello reale emesso dal treno, ha:",
            risposte: [
                { "visibile": "A) Una frequenza maggiore (suono più acuto)", "feedback": "Corretto!" },
                { "visibile": "B) Una frequenza minore (suono più grave)", "feedback": "Errato!" },
                { "visibile": "C) La stessa frequenza ma un'intensità minore", "feedback": "Errato!" },
                { "visibile": "D) Una velocità di propagazione nell'aria maggiore", "feedback": "Errato!" }
            ]
        },
        {
            domanda: "Qual è la causa principale dell'effetto Doppler?",
            risposte: [
                { "visibile": "A) La riflessione delle onde sonore su una superficie", "feedback": "Errato!" },
                { "visibile": "B) Il moto relativo tra la sorgente dell'onda e l'osservatore", "feedback": "Corretto!" },
                { "visibile": "C) Il cambiamento del mezzo di propagazione dell'onda", "feedback": "Errato!" },
                { "visibile": "D) La diminuzione dell'energia dell'onda nel tempo", "feedback": "Errato!" }
            ]
        },
        {
            domanda: "Durante l'effetto Doppler per le onde sonore in aria, quale delle seguenti grandezze NON cambia a causa del movimento della sorgente?",
            risposte: [
                { "visibile": "A) La frequenza dell'onda percepita dall'osservatore", "feedback": "Errato!" },
                { "visibile": "B) La lunghezza d'onda percepita dall'osservatore", "feedback": "Errato!" },
                { "visibile": "C) La velocità di propagazione del suono nell'aria", "feedback": "Corretto!" },
                { "visibile": "D) Il periodo dell'onda misurato dall'osservatore", "feedback": "Errato!" }
            ]
        }
    ];

    // Inizializza lo stato "grattato" per ogni risposta
    DATABASE_DOMANDE.forEach(d => d.risposte.forEach(r => r.grattato = false));

    // ==========================================
    // 2. MOTORE DEL QUIZ
    // ==========================================
    let paginaCorrente = 0;

    function renderQuestion() {
        const quizContainer = document.getElementById('quiz-container');
        const d = DATABASE_DOMANDE[paginaCorrente];
        
        quizContainer.innerHTML = `
            <div class="question-card">
                <div class="question-text">${paginaCorrente + 1}. ${d.domanda}</div>
                <div id="options-list"></div>
            </div>
        `;

        const optionsList = document.getElementById('options-list');
        
        d.risposte.forEach((opt, index) => {
            const row = document.createElement('div');
            row.className = 'option-row';
            
            const isCorrect = opt.feedback.trim().startsWith("Corretto!");
            const resultClass = isCorrect ? 'correct' : 'wrong';
            const icon = isCorrect ? '🏆 ' : '❌ ';
            
            row.innerHTML = `
                <div class="visible-option">${opt.visibile}</div>
                <div class="scratch-wrapper">
                    <div id="feedback-${index}" class="feedback-content ${resultClass}">${icon}${opt.feedback}</div>
                    <canvas class="scratch-canvas" id="canvas-${index}"></canvas>
                </div>
            `;
            
            optionsList.appendChild(row);
            setTimeout(() => initScratch(index, opt), 50);
        });

        document.getElementById('pageInfo').innerText = `Domanda ${paginaCorrente + 1} di ${DATABASE_DOMANDE.length}`;
        document.getElementById('prevBtn').disabled = paginaCorrente === 0;
        document.getElementById('nextBtn').disabled = paginaCorrente === DATABASE_DOMANDE.length - 1;
    }

    function initScratch(index, opt) {
        const canvas = document.getElementById(`canvas-${index}`);
        const ctx = canvas.getContext('2d');
        const parent = canvas.parentElement;
        
        canvas.width = parent.offsetWidth;
        canvas.height = parent.offsetHeight;

        if (opt.grattato) {
            document.getElementById(`feedback-${index}`).style.opacity = '1';
            return; 
        }

        ctx.fillStyle = '#bdc3c7';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        ctx.fillStyle = '#95a5a6';
        for(let i=0; i<100; i++) {
            ctx.beginPath();
            ctx.arc(Math.random()*canvas.width, Math.random()*canvas.height, Math.random()*2, 0, Math.PI*2);
            ctx.fill();
        }

        ctx.fillStyle = '#2c3e50';
        ctx.font = 'bold 16px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('GRATTA QUI', canvas.width/2, canvas.height/2);

        document.getElementById(`feedback-${index}`).style.opacity = '1';

        let isDrawing = false;

        function getCoordinates(e) {
            const rect = canvas.getBoundingClientRect();
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            return {
                x: clientX - rect.left,
                y: clientY - rect.top
            };
        }

        function scratch(e) {
            if (!isDrawing) return;
            e.preventDefault(); 
            
            opt.grattato = true;
            const pos = getCoordinates(e);
            
            ctx.globalCompositeOperation = 'destination-out';
            ctx.beginPath();
            ctx.arc(pos.x, pos.y, 25, 0, Math.PI * 2); 
            ctx.fill();
        }

        canvas.addEventListener('mousedown', () => isDrawing = true);
        canvas.addEventListener('touchstart', (e) => { isDrawing = true; e.preventDefault(); }, {passive: false});
        
        window.addEventListener('mouseup', () => isDrawing = false);
        window.addEventListener('touchend', () => isDrawing = false);
        
        canvas.addEventListener('mousemove', scratch);
        canvas.addEventListener('touchmove', scratch, {passive: false});
    }

    function changePage(step) {
        paginaCorrente += step;
        renderQuestion();
    }

    window.addEventListener('resize', renderQuestion);
    window.onload = renderQuestion;
</script>

</body>
</html>